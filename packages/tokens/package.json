{
  "name": "@eni/tokens",
  "version": "0.0.0",
  "description": "Design tokens — colors, spacing, typography, motion, radii",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./css": "./build/css/tokens.css",
    "./js": "./build/js/index.mjs"
  },
  "files": ["build", "src"],
  "scripts": {
    "build": "tsx style-dictionary.config.ts",
    "dev": "tsx --watch style-dictionary.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src"
  },
  "publishConfig": {
    "registry": "https://asia-northeast1-npm.pkg.dev/eni-trance/enidesign/"
  },
  "devDependencies": {
    "@eni/config": "workspace:*",
    "style-dictionary": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
