{
  "name": "@eni/api-client",
  "version": "0.0.0",
  "description": "GraphQL client for EniDB — auto-generated hooks and types via codegen",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./src/generated/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "graphql-codegen --config codegen.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src"
  },
  "dependencies": {
    "@eni/schemas": "workspace:*"
  },
  "devDependencies": {
    "@eni/config": "workspace:*",
    "@graphql-codegen/cli": "^5.0.3",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
